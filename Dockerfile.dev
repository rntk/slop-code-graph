FROM python:3.12-slim

# Install system deps for tree-sitter compilation and general dev tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    make \
    gcc \
    libc6-dev \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root user with stable UID/GID
RUN groupadd --gid 1000 appuser \
 && useradd --uid 1000 --gid 1000 --create-home appuser

WORKDIR /app

# Install dev dependencies as root
COPY requirements.txt requirements-dev.txt pyproject.toml ./
RUN pip install --no-cache-dir -r requirements-dev.txt

# Copy source and hand ownership to appuser
COPY . .
RUN chown -R appuser:appuser /app

USER appuser

# Default command runs the full dev check suite
CMD ["make", "check"]
